# ============================================================
#                    CẤU HÌNH BOT TELEGRAM
# ============================================================

# ==================== BẮT BUỘC ====================

# Token bot từ @BotFather
BOT_TOKEN=your_bot_token_here

# Telegram ID của admin (lấy từ @userinfobot)
ADMIN_ID=123456789

# ==================== ADMIN PANEL ====================

# Tên đăng nhập admin panel (mặc định: admin)
ADMIN_USERNAME=admin

# Mật khẩu admin panel (mặc định: admin123)
# ⚠️ HÃY ĐỔI MẬT KHẨU NÀY!
ADMIN_PASSWORD=your_secure_password_here

# ==================== THANH TOÁN TỰ ĐỘNG ====================

# API Key từ SePay (https://my.sepay.vn)
# Đăng ký → Cài đặt → API Key
SEPAY_API_KEY=

# API Key từ Casso (https://casso.vn) - Tùy chọn thay thế SePay
CASSO_API_KEY=

# ==================== LIÊN HỆ HỖ TRỢ ====================

# Link Zalo hỗ trợ khách hàng
# VD: https://zalo.me/0123456789
ZALO_LINK=

# Link kênh/group Telegram
# VD: https://t.me/your_channel
TELEGRAM_CHANNEL=

# ==================== CẤU HÌNH KHÁC (Tùy chọn) ====================

# Đường dẫn file database (mặc định: shop.db)
# DB_PATH=shop.db

# Port chạy server (mặc định: 8080)
# PORT=8080
